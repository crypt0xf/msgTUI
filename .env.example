# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git

# Senha do banco PostgreSQL (use algo forte, ex: openssl rand -hex 20)
DB_PASSWORD=troque_por_senha_forte_aqui

# Segredo JWT (obrigatório, 64 hex chars recomendado)
# Gere com: python scripts/generate_secrets.py
JWT_SECRET=troque_por_segredo_jwt_aqui

# Porta exposta no host (padrão 8765)
SERVER_PORT=8765

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cloudflare Tunnel
# Deixe vazio para tunnel rápido (URL temporária, sem conta)
# Cole o token do painel Cloudflare para tunnel permanente
TUNNEL_TOKEN=
